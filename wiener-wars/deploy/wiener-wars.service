[Unit]
Description=Wiener Wars hotdog tracker
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/wiener-wars
ExecStart=/usr/bin/node /opt/wiener-wars/server.js
Environment=PORT=80
Environment=SIGNUP_KEY=CHANGE_ME
# allow binding to port 80 without running as full root
AmbientCapabilities=CAP_NET_BIND_SERVICE
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
